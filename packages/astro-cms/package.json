{
  "name": "@mattthehat/astro-cms",
  "version": "0.1.0",
  "type": "module",
  "license": "MIT",
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "src",
    "styles",
    "README.md"
  ],
  "scripts": {
    "build:css": "sass styles/cms.scss styles/cms.css --style=compressed --no-source-map",
    "check": "astro check",
    "prepublishOnly": "pnpm build:css && cp ../../README.md ./README.md",
    "test": "vitest run"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@mattthehat/astro-forms": "^0.1.0",
    "astro": "^6.4.5",
    "atlas-mysql": "^4.1.1",
    "sass": "^1.101.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "@mattthehat/astro-forms": "^0.1.0",
    "astro": "^6.4.5",
    "atlas-mysql": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "atlas-mysql": {
      "optional": true
    }
  },
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./styles/cms.css",
    "./styles.scss": "./styles/cms.scss",
    "./Cms.astro": "./src/components/Cms.astro",
    "./adapters/atlas-mysql": "./src/adapters/atlas-mysql.ts",
    "./adapters/memory": "./src/adapters/memory.ts"
  }
}
