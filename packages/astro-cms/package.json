{
  "name": "@mattthehat/astro-cms",
  "version": "0.2.0",
  "description": "Config-driven admin CMS for Astro: one resource config renders a full list/create/edit/view/delete screen with search, filters, sorting and pagination, DB-agnostic via a small adapter interface.",
  "type": "module",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mattthehat/astro-cms.git",
    "directory": "packages/astro-cms"
  },
  "homepage": "https://github.com/mattthehat/astro-cms#readme",
  "bugs": "https://github.com/mattthehat/astro-cms/issues",
  "keywords": [
    "astro",
    "astro-component",
    "cms",
    "admin",
    "crud",
    "withastro"
  ],
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "src",
    "styles",
    "README.md"
  ],
  "scripts": {
    "build:css": "sass styles/cms.scss styles/cms.css --style=compressed --no-source-map",
    "check": "astro check",
    "prepublishOnly": "pnpm build:css && cp ../../README.md ./README.md",
    "test": "vitest run"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@mattthehat/astro-forms": "^0.2.0",
    "astro": "^6.4.5",
    "atlas-mysql": "^4.1.1",
    "sass": "^1.101.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.10"
  },
  "peerDependencies": {
    "@mattthehat/astro-forms": "^0.2.0",
    "astro": "^6.4.5",
    "atlas-mysql": "^4.0.0"
  },
  "peerDependenciesMeta": {
    "atlas-mysql": {
      "optional": true
    }
  },
  "exports": {
    ".": "./src/index.ts",
    "./styles.css": "./styles/cms.css",
    "./styles.scss": "./styles/cms.scss",
    "./Cms.astro": "./src/components/Cms.astro",
    "./adapters/atlas-mysql": "./src/adapters/atlas-mysql.ts",
    "./adapters/memory": "./src/adapters/memory.ts"
  }
}
